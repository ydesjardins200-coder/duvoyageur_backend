# Copy to .env for local dev, or set these in Railway → Variables.
# NEVER commit the real .env.

# --- Database -------------------------------------------------------------
# Supabase: Project → Settings → Database → Connection string (URI).
# Railway:  add a Postgres plugin, it injects DATABASE_URL automatically.
# Leave unset locally to use SQLite (sqlite:///./dev.db).
DATABASE_URL=

# --- Anthropic (the parser) ----------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
PARSE_MODEL=claude-sonnet-4-6

# --- Facebook Messenger ---------------------------------------------------
# FB_VERIFY_TOKEN: invent any random string; you paste the SAME one into Meta.
FB_VERIFY_TOKEN=pick-a-random-string
# FB_APP_SECRET: Meta app → Settings → Basic → App Secret. Verifies payloads.
FB_APP_SECRET=
# FB_PAGE_TOKEN: needed later to send replies back to customers.
FB_GRAPH_VERSION=v21.0
FB_PAGE_TOKEN=

# --- Admin panel ----------------------------------------------------------
ADMIN_USER=admin
ADMIN_PASSWORD=set-a-strong-password
# SECRET_KEY signs the login session cookie. Set a long random value in prod
# and keep it stable. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=dev-only-insecure-change-me
# Session length in seconds (default 14 days).
SESSION_MAX_AGE=1209600
# Set to 1 in production (HTTPS) so the cookie is HTTPS-only. Leave unset locally.
SECURE_COOKIES=

# --- CORS: your Netlify (and live) domains, comma-separated ---------------
ALLOWED_ORIGINS=https://your-site.netlify.app,https://duvoyageur.ca

# Testing only: set to 1 to enable the "wipe all cases" button in admin.
# Leave UNSET in production.
ALLOW_RESET=

# Seconds to wait before auto-replying, so text+screenshot bursts get one reply.
ACK_DEBOUNCE_SECONDS=5

# Answer general questions with a short concierge reply (1=on, 0=off).
CONCIERGE_ENABLED=1
